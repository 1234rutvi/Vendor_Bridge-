import React, { useState, useEffect } from 'react';
import { Mail, Lock, AlertCircle, CheckCircle, ArrowLeft } from 'lucide-react';
import { useNavigate } from 'react-router-dom';
import logoImg from '../assets/logo1.png';
import { validateEmail, checkPasswordStrength, getStrengthBarClass } from '../utils/validation';

export default function ForgotPassword() {
  const navigate = useNavigate();

  const [forgotData, setForgotData] = useState({
    email: '',
    newPassword: '',
    confirmPassword: ''
  });
  const [forgotErrors, setForgotErrors] = useState({});
  const [forgotSuccess, setForgotSuccess] = useState('');
  const [usersDb, setUsersDb] = useState([]);

  useEffect(() => {
    const saved = localStorage.getItem('vb_users');
    if (saved) {
      setUsersDb(JSON.parse(saved));
    }
  }, []);

  const handleForgotSubmit = (e) => {
    e.preventDefault();
    setForgotErrors({});
    setForgotSuccess('');
    const errors = {};

    if (!forgotData.email) {
      errors.email = 'Email address is required.';
    } else if (!validateEmail(forgotData.email)) {
      errors.email = 'Please enter a valid email format.';
    }

    const foundUserIndex = usersDb.findIndex(u => u.email.toLowerCase() === forgotData.email.toLowerCase());
    if (foundUserIndex === -1 && validateEmail(forgotData.email)) {
      errors.email = 'No registered account found with this email.';
    }

    const { score, checks } = checkPasswordStrength(forgotData.newPassword);
    if (!forgotData.newPassword) {
      errors.newPassword = 'New password is required.';
    } else if (!checks.length) {
      errors.newPassword = 'Password must be at least 8 characters long.';
    } else if (score < 5) {
      errors.newPassword = 'Password must include uppercase, lowercase, digit, and special characters.';
    }

    if (forgotData.newPassword !== forgotData.confirmPassword) {
      errors.confirmPassword = 'Passwords do not match.';
    }

    if (Object.keys(errors).length > 0) {
      setForgotErrors(errors);
      return;
    }

    const updatedDb = [...usersDb];
    updatedDb[foundUserIndex].password = forgotData.newPassword;
    localStorage.setItem('vb_users', JSON.stringify(updatedDb));
    setUsersDb(updatedDb);

    setForgotSuccess('Password successfully reset! You can now log in with your new credentials.');
    setForgotData({ email: '', newPassword: '', confirmPassword: '' });
  };

  return (
    <div className="auth-wrapper">
      <div className="glass-panel auth-card animate-fade-in">
        <div className="auth-header">
          <div style={{ display: 'flex', justifyContent: 'center', marginBottom: '0.5rem' }}>
            <img 
              src={logoImg} 
              alt="Vendor Bridge Logo" 
              style={{ height: '80px', objectFit: 'contain' }} 
            />
          </div>
        </div>

        <form onSubmit={handleForgotSubmit} className="auth-form">
          {forgotSuccess && (
            <div className="auth-success-msg" style={{ background: 'var(--success-glow)', padding: '12px', borderRadius: '8px', border: '1px solid rgba(16, 185, 129, 0.2)', color: 'var(--success)', display: 'flex', gap: '8px', alignItems: 'flex-start', fontSize: '0.85rem' }}>
              <CheckCircle size={18} style={{ flexShrink: 0, marginTop: '2px' }} />
              <span>{forgotSuccess}</span>
            </div>
          )}

  

          <div>
            <label className="auth-label">New Password</label>
            <div className="auth-input-icon-wrapper">
              <Lock size={16} className="auth-input-icon" />
              <input
                type="password"
                placeholder="••••••••••••"
                value={forgotData.newPassword}
                disabled={!!forgotSuccess}
                onChange={e => setForgotData({ ...forgotData, newPassword: e.target.value })}
                className="form-input auth-input-with-icon"
              />
            </div>
            {forgotData.newPassword && (
              <div>
                <div className="auth-strength-meter">
                  {[0, 1, 2, 3, 4].map((idx) => {
                    const { checks } = checkPasswordStrength(forgotData.newPassword);
                    return (
                      <div 
                        key={idx} 
                        className={`auth-strength-bar ${getStrengthBarClass(checks, idx)}`}
                      ></div>
                    );
                  })}
                </div>
              </div>
            )}
            {forgotErrors.newPassword && <div className="auth-error-msg"><AlertCircle size={12} /> {forgotErrors.newPassword}</div>}
          </div>

          <div>
            <label className="auth-label">Confirm New Password</label>
            <div className="auth-input-icon-wrapper">
              <Lock size={16} className="auth-input-icon" />
              <input
                type="password"
                placeholder="••••••••••••"
                value={forgotData.confirmPassword}
                disabled={!!forgotSuccess}
                onChange={e => setForgotData({ ...forgotData, confirmPassword: e.target.value })}
                className="form-input auth-input-with-icon"
              />
            </div>
            {forgotErrors.confirmPassword && <div className="auth-error-msg"><AlertCircle size={12} /> {forgotErrors.confirmPassword}</div>}
          </div>

          {!forgotSuccess ? (
            <button type="submit" className="btn btn-primary" style={{ width: '100%', justifyContent: 'center', marginTop: '0.5rem' }}>
              Reset Account Password
            </button>
          ) : (
            <button 
              type="button" 
              onClick={() => navigate('/login')} 
              className="btn btn-primary" 
              style={{ width: '100%', justifyContent: 'center', marginTop: '0.5rem' }}
            >
              Go to Sign In
            </button>
          )}

          <div className="auth-footer" style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '6px' }}>
            <ArrowLeft size={14} color="var(--primary)" />
            <span className="auth-link" onClick={() => navigate('/login')}>
              Back to Login
            </span>
          </div>
        </form>
      </div>
    </div>
  );
}
