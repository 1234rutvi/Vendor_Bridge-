                    {selectedCategory === 'all' ? '$120K' : selectedCategory === 'infra' ? '$80K' : selectedCategory === 'office' ? '$25K' : selectedCategory === 'hardware' ? '$20K' : '$15K'}
                  </text>
                  <text x="32" y="74" textAnchor="end" fill="var(--text-dark)" fontSize="9" fontWeight="500">
                    {selectedCategory === 'all' ? '$80K' : selectedCategory === 'infra' ? '$50K' : selectedCategory === 'office' ? '$16K' : selectedCategory === 'hardware' ? '$13K' : '$10K'}
                  </text>
                  <text x="32" y="114" textAnchor="end" fill="var(--text-dark)" fontSize="9" fontWeight="500">
                    {selectedCategory === 'all' ? '$40K' : selectedCategory === 'infra' ? '$25K' : selectedCategory === 'office' ? '$8K' : selectedCategory === 'hardware' ? '$6K' : '$5K'}
                  </text>
                  <text x="32" y="154" textAnchor="end" fill="var(--text-dark)" fontSize="9" fontWeight="500">$0</text>

                  {/* SVG Area & Line Path */}
                  <path d={areaPath} fill="url(#chart-grad)" style={{ transition: 'all 0.3s ease' }} />
                  <path d={linePath} fill="none" stroke={activeConf.color} strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" style={{ transition: 'all 0.3s ease' }} />

                  {/* SVG Graph Interactive Nodes */}
                  {pts.map((pt, idx) => {
                    const isHovered = hoveredChartItem === `node-${idx}`;
                    return (
                      <g key={idx}>
                        {isHovered && (
                          <line x1={pt.x} y1="30" x2={pt.x} y2="150" stroke="rgba(255,255,255,0.08)" strokeWidth="1" />
                        )}
                        <circle 
                          cx={pt.x} 
                          cy={pt.y} 
                          r={isHovered ? 6 : 3.5} 
                          fill="#ffffff" 
                          stroke={activeConf.color} 
                          strokeWidth="2.5" 
                          style={{ transition: 'r 0.15s ease', cursor: 'pointer' }}
                        />
                        <circle 
                          cx={pt.x} 
                          cy={pt.y} 
                          r="16" 
                          fill="transparent" 
                          style={{ cursor: 'pointer' }}
                          onMouseEnter={() => setHoveredChartItem(`node-${idx}`)}
                          onMouseLeave={() => setHoveredChartItem(null)}
                        />
                        <text x={pt.x} y="166" textAnchor="middle" fill={isHovered ? '#ffffff' : 'var(--text-muted)'} fontSize="9" fontWeight={isHovered ? '600' : '500'}>
