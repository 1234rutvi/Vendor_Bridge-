                        <div>Hardware: ${chartData[parseInt(hoveredChartItem.split('-')[1])].hardware.toLocaleString()} | Software: ${chartData[parseInt(hoveredChartItem.split('-')[1])].software.toLocaleString()}</div>
                      </div>
                    )}
                  </>
