                    <linearGradient id="chart-grad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stopColor={activeConf.color} stopOpacity="0.3" />
                      <stop offset="100%" stopColor={activeConf.color} stopOpacity="0.0" />
