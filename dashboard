            <div style={styles.quickActionsGrid}>
              <button className="quick-action-btn" onClick={() => setShowRfqModal(true)}>
                <Plus size={16} />
                <span>New RFQ</span>
              </button>
              
              <button className="quick-action-btn" onClick={() => onNavigate('vendors')}>
