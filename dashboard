              </button>
            </div>
          </div>
        </div>

      </div>

      {/* Create RFQ Dialog Modal overlay */}
      {showRfqModal && (
        <div style={styles.modalOverlay} onClick={() => setShowRfqModal(false)}>
          <div className="glass-panel animate-fade-in" style={styles.modalContent} onClick={e => e.stopPropagation()}>
            <div style={styles.modalHeader}>
              <h3 style={{ margin: 0, color: '#ffffff' }}>Create Request for Quotation</h3>
              <button style={styles.closeModalBtn} onClick={() => setShowRfqModal(false)}>
                <X size={18} />
              </button>
            </div>
            
            <form onSubmit={handleCreateRfq} style={styles.modalForm}>
              <div style={styles.formGroup}>
                <label style={styles.label}>RFQ Title / Requisition Item</label>
                <input 
                  type="text" 
                  className="form-input" 
                  placeholder="e.g. Raw PCB Core Material 500 units"
                  required
                  value={newRfqData.title}
                  onChange={e => setNewRfqData({ ...newRfqData, title: e.target.value })}
                />
              </div>

              <div style={styles.formRow}>
                <div style={styles.formGroup}>
                  <label style={styles.label}>Estimated Budget ($)</label>
                  <input 
                    type="number" 
                    className="form-input" 
                    placeholder="e.g. 15000"
                    value={newRfqData.budget}
                    onChange={e => setNewRfqData({ ...newRfqData, budget: e.target.value })}
                  />
                </div>
                <div style={styles.formGroup}>
                  <label style={styles.label}>Submission Deadline</label>
                  <input 
                    type="date" 
                    className="form-input" 
                    required
                    value={newRfqData.deadline}
                    onChange={e => setNewRfqData({ ...newRfqData, deadline: e.target.value })}
                  />
                </div>
              </div>

              <div style={styles.modalActions}>
                <button type="submit" className="btn btn-primary" style={{ flex: 1, justifyContent: 'center' }}>
                  Publish RFQ
                </button>
                <button 
                  type="button" 
                  className="btn btn-secondary" 
                  onClick={() => setShowRfqModal(false)}
                  style={{ flex: 1, justifyContent: 'center' }}
