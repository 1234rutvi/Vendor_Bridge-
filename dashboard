import React, { useState, useEffect } from 'react';
import { 
  CheckSquare, 
  FileText, 
  ShoppingBag, 
  AlertCircle, 
  Plus, 
  Check, 
  X, 
  RefreshCw, 
  Search, 
  DollarSign, 
  User
} from 'lucide-react';

// Roles greeting translation mapping
const getRoleLabel = (role) => {
  switch (role) {
    case 'admin':
      return 'System Admin';
    case 'officer':
      return 'Procurement Officer';
    case 'vendor':
      return 'Vendor Operator';
    default:
      return 'Procurement Officer';
  }
};

export default function DashboardOverview({ currentUser, onNavigate, stats = {}, triggerSync, isSyncing }) {
  const roleLabel = currentUser ? getRoleLabel(currentUser.role) : 'Procurement Officer';

  // --- Stateful Procurement Mock Data ---
  const [approvals, setApprovals] = useState([
    { id: 'app-1', title: 'Industrial Grade Server Upgrade', vendor: 'Tech Core', amount: 12500, requestor: 'Sarah Jenkins', date: '2026-06-05', type: 'Purchase Requisition' },
    { id: 'app-2', title: 'High-Performance Fiber Optic Cables', vendor: 'Infra', amount: 3200, requestor: 'David Miller', date: '2026-06-06', type: 'Price Deviation' },
    { id: 'app-3', title: 'Warehouse Storage Rack Installation', vendor: 'OfficeNeed Co', amount: 8900, requestor: 'Elena Rostova', date: '2026-06-04', type: 'Contract Approval' }
  ]);

  const [rfqs, setRfqs] = useState([
    { id: 'rfq-1', rfqNo: 'RFQ-2026-008', title: 'High-Capacity SSDs & RAM Blocks', vendorCount: 4, deadline: '2026-06-12', status: 'Bidding Open', budget: 15000 },
    { id: 'rfq-2', rfqNo: 'RFQ-2026-009', title: 'Ergonomic Standing Desks Phase 2', vendorCount: 2, deadline: '2026-06-18', status: 'Draft', budget: 6500 },
    { id: 'rfq-3', rfqNo: 'RFQ-2026-010', title: 'Custom Aluminum Extrusion Brackets', vendorCount: 5, deadline: '2026-06-10', status: 'Bids Received', budget: 24000 }
  ]);

  const [purchaseOrders, setPurchaseOrders] = useState([
    { id: 'po-1', poNo: 'PO-2026-091', vendor: 'Infra', amount: 87000, date: '2026-06-06', status: 'Approved', syncStatus: 'synced' },
    { id: 'po-2', poNo: 'PO-2026-092', vendor: 'Tech Core', amount: 140000, date: '2026-06-05', status: 'Pending', syncStatus: 'pending' },
    { id: 'po-3', poNo: 'PO-2026-093', vendor: 'OfficeNeed Co', amount: 34900, date: '2026-06-04', status: 'Draft', syncStatus: 'unsynced' }
  ]);

  const [invoices, setInvoices] = useState([
    { id: 'inv-1', invNo: 'INV-78901', poRef: 'PO-2026-091', vendor: 'Infra', amount: 12000, dueDate: '2026-06-15', status: 'Open', syncStatus: 'synced' },
    { id: 'inv-2', invNo: 'INV-78902', poRef: 'PO-2026-093', vendor: 'OfficeNeed Co', amount: 4500, dueDate: '2026-06-02', status: 'Overdue', syncStatus: 'synced' },
    { id: 'inv-3', invNo: 'INV-78903', poRef: 'PO-2026-092', vendor: 'Tech Core', amount: 87000, dueDate: '2026-07-01', status: 'Paid', syncStatus: 'synced' }
  ]);

  // --- Interaction States ---
  const [activeTab, setActiveTab] = useState('pos'); // 'pos', 'invoices', 'rfqs'
  const [searchQuery, setSearchQuery] = useState('');
  const [showRfqModal, setShowRfqModal] = useState(false);
  const [newRfqData, setNewRfqData] = useState({ title: '', budget: '', vendor: '', deadline: '' });
  const [toasts, setToasts] = useState([]);
  const [removingApprovalId, setRemovingApprovalId] = useState(null);
  const [highlightedCard, setHighlightedCard] = useState(null);
  const [hoveredChartItem, setHoveredChartItem] = useState(null);
  const [selectedCategory, setSelectedCategory] = useState('all');

  // --- Spending Trends Calculations ---
  const chartData = [
    { month: 'Jan', total: 45000, infra: 25000, office: 10000, hardware: 6000, software: 4000 },
    { month: 'Feb', total: 68000, infra: 38000, office: 12000, hardware: 11000, software: 7000 },
    { month: 'Mar', total: 55000, infra: 30000, office: 9000, hardware: 10000, software: 6000 },
    { month: 'Apr', total: 90000, infra: 54000, office: 16000, hardware: 12000, software: 8000 },
    { month: 'May', total: 75000, infra: 45000, office: 13000, hardware: 10000, software: 7000 },
    { month: 'Jun', total: 115000, infra: 72000, office: 18000, hardware: 15000, software: 10000 },
  ];

  const categoryConfig = {
    all: { label: 'All Spent', color: '#6366f1', gradientId: 'grad-all' },
    infra: { label: 'Infrastructure', color: '#38bdf8', gradientId: 'grad-infra' },
    office: { label: 'Office Supplies', color: '#34d399', gradientId: 'grad-office' },
    hardware: { label: 'Hardware', color: '#f87171', gradientId: 'grad-hardware' },
    software: { label: 'Software', color: '#fbbf24', gradientId: 'grad-software' }
  };

  const activeConf = categoryConfig[selectedCategory] || categoryConfig.all;
  const maxVal = selectedCategory === 'all' ? 120000 : selectedCategory === 'infra' ? 80000 : selectedCategory === 'office' ? 25000 : selectedCategory === 'hardware' ? 20000 : 15000;
  
  const pts = chartData.map((d, i) => {
    const val = selectedCategory === 'all' ? d.total : d[selectedCategory];
    const x = 50 + i * 72;
    const y = 150 - (val / maxVal) * 110;
    return { x, y, val, month: d.month };
  });

  const linePath = `M ${pts.map(p => `${p.x} ${p.y}`).join(' L ')}`;
  const areaPath = `${linePath} L ${pts[pts.length - 1].x} 150 L ${pts[0].x} 150 Z`;

  // --- Toast Trigger Helper ---
  const showToast = (message, type = 'success') => {
    const newToast = { id: Date.now(), message, type };
    setToasts(prev => [...prev, newToast]);
    setTimeout(() => {
      setToasts(prev => prev.filter(t => t.id !== newToast.id));
    }, 4000);
  };

  // --- Odoo Sync Monitor ---
  useEffect(() => {
    if (isSyncing) {
      showToast('Connecting Odoo v17 Bridge: Syncing procurement databases...', 'info');
    } else if (stats.lastSync && stats.lastSync !== 'Never') {
      showToast('Odoo bridge databases synchronized successfully!', 'success');
      // Randomly mock pull of a new purchase order or invoice from Odoo
      if (Math.random() > 0.4) {
        const vendorsList = ['Amazon US Marketplace', 'Shopify Storefront (Retail)', 'Walmart Wholesale Portal'];
        const randomVendor = vendorsList[Math.floor(Math.random() * vendorsList.length)];
        const amount = Math.floor(Math.random() * 45000) + 5000;
        const newPoNo = `PO-2026-09${purchaseOrders.length + 4}`;
        
        setPurchaseOrders(prev => [
          {
            id: `po-${Date.now()}`,
            poNo: newPoNo,
            vendor: randomVendor,
            amount: amount,
            date: new Date().toISOString().split('T')[0],
            status: 'Approved',
            syncStatus: 'synced'
          },
          ...prev
        ]);
      }
    }
  }, [isSyncing]);

  // --- Dynamic Stats Calculations ---
  const activeRfqsCount = rfqs.length;
  const pendingApprovalsCount = approvals.length;
  const overdueInvoicesCount = invoices.filter(inv => inv.status === 'Overdue').length;

  const getPoVolumeStr = () => {
    const totalPoSum = purchaseOrders.reduce((sum, po) => sum + po.amount, 0);
    if (totalPoSum >= 100000) {
      return `$ ${(totalPoSum / 100000).toFixed(1)}L`;
    }
    return `$ ${(totalPoSum / 1000).toFixed(1)}K`;
  };

  // --- Approval Queue Actions ---
  const handleResolveApproval = (id, action, title) => {
    setRemovingApprovalId(id);
    setTimeout(() => {
      setApprovals(prev => prev.filter(item => item.id !== id));
      setRemovingApprovalId(null);
      showToast(
        action === 'approve' 
          ? `Approved request: "${title}"` 
          : `Declined request: "${title}"`,
        action === 'approve' ? 'success' : 'error'
      );
    }, 300);
  };

  // --- Invoice Payment Actions ---
  const handlePayInvoice = (id, invNo) => {
    setInvoices(prev => prev.map(inv => {
      if (inv.id === id) {
        showToast(`Invoice ${invNo} marked as Paid & queued for Odoo reconciliation.`);
        return { ...inv, status: 'Paid' };
      }
      return inv;
    }));
  };

  // --- Create RFQ Form Submission ---
  const handleCreateRfq = (e) => {
    e.preventDefault();
    if (!newRfqData.title || !newRfqData.deadline) {
      showToast('Please specify a Title and Deadline.', 'error');
      return;
    }
    const newRfq = {
      id: `rfq-${Date.now()}`,
      rfqNo: `RFQ-2026-0${rfqs.length + 9}`,
      title: newRfqData.title,
      vendorCount: 0,
      deadline: newRfqData.deadline,
      status: 'Draft',
      budget: Number(newRfqData.budget) || 0
    };
    setRfqs(prev => [newRfq, ...prev]);
    setShowRfqModal(false);
    setNewRfqData({ title: '', budget: '', vendor: '', deadline: '' });
    setActiveTab('rfqs');
    showToast(`Successfully created ${newRfq.rfqNo}!`);
  };

  // --- Filter Logic for Activity Lists ---
  const getFilteredData = () => {
    const q = searchQuery.toLowerCase();
    switch (activeTab) {
      case 'pos':
        return purchaseOrders.filter(po => 
          po.poNo.toLowerCase().includes(q) || 
          po.vendor.toLowerCase().includes(q)
        );
      case 'invoices':
        return invoices.filter(inv => 
          inv.invNo.toLowerCase().includes(q) || 
          inv.vendor.toLowerCase().includes(q) || 
          inv.poRef.toLowerCase().includes(q)
        );
      case 'rfqs':
        return rfqs.filter(rfq => 
          rfq.rfqNo.toLowerCase().includes(q) || 
          rfq.title.toLowerCase().includes(q)
        );
      default:
        return [];
    }
  };

  const currentListData = getFilteredData();

  // --- Dynamic Highlight for Stats click ---
  const handleCardClick = (tabKey) => {
    setHighlightedCard(tabKey);
    setTimeout(() => setHighlightedCard(null), 1000);
    if (tabKey === 'approvals') {
      const el = document.getElementById('approvals-section');
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    } else {
      setActiveTab(tabKey);
      const el = document.getElementById('activity-table-section');
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    }
  };

  return (
    <div className="dashboard-wrapper animate-fade-in" style={styles.container}>
      <style>{extraCSS}</style>

      {/* Real-time Toast Notifications Container */}
      <div style={styles.toastContainer}>
        {toasts.map(toast => (
          <div 
            key={toast.id} 
            className={`toast-alert toast-${toast.type} animate-slide-in`}
            style={styles.toastItem}
          >
            {toast.type === 'success' && <Check size={16} />}
            {toast.type === 'error' && <X size={16} />}
            {toast.type === 'info' && <RefreshCw size={16} className="animate-spin" />}
            <span>{toast.message}</span>
          </div>
        ))}
      </div>

      {/* Header section */}
      <div style={styles.header}>
        <div style={styles.headerLeft}>
          <h1 style={styles.title}>Procurement Dashboard</h1>
          <p style={styles.subtitle}>Welcome back, {roleLabel} - Real-time Odoo & Vendor Bridge monitoring</p>
        </div>
        <div style={styles.headerRight}>
          <button 
            className={`sync-trigger-btn ${isSyncing ? 'loading' : ''}`}
            onClick={triggerSync}
            disabled={isSyncing}
            style={styles.syncBtn}
          >
            <RefreshCw size={15} style={isSyncing ? styles.spinning : {}} />
            <span>{isSyncing ? 'Syncing...' : 'Sync Odoo'}</span>
          </button>
        </div>
      </div>

      {/* Stats Cards Row */}
      <div className="dashboard-stats-grid" style={styles.statsRow}>
        {/* Card 1: Active RFQs */}
        <div 
          className={`glass-stat-card ${highlightedCard === 'rfqs' ? 'card-pulse' : ''}`}
          style={{ ...styles.statCard, cursor: 'pointer' }}
          onClick={() => handleCardClick('rfqs')}
        >
          <div style={styles.statIconContainer}>
            <FileText size={20} color="#38bdf8" />
          </div>
          <div style={styles.statNumber}>{activeRfqsCount}</div>
          <div style={styles.statLabel}>Active RFQs</div>
        </div>

        {/* Card 2: Pending Approvals */}
        <div 
          className={`glass-stat-card ${highlightedCard === 'approvals' ? 'card-pulse' : ''}`}
          style={{ ...styles.statCard, cursor: 'pointer' }}
          onClick={() => handleCardClick('approvals')}
        >
          <div style={styles.statIconContainer}>
            <CheckSquare size={20} color="#a5b4fc" />
          </div>
          <div style={styles.statNumber}>{pendingApprovalsCount}</div>
          <div style={styles.statLabel}>Pending Approvals</div>
        </div>

        {/* Card 3: PO Volume this month */}
        <div 
          className={`glass-stat-card ${highlightedCard === 'pos' ? 'card-pulse' : ''}`}
          style={{ ...styles.statCard, cursor: 'pointer' }}
          onClick={() => handleCardClick('pos')}
        >
          <div style={styles.statIconContainer}>
            <ShoppingBag size={20} color="#34d399" />
          </div>
          <div style={styles.statNumber}>{getPoVolumeStr()}</div>
          <div style={styles.statLabel}>PO Volume</div>
        </div>

        {/* Card 4: Overdue Invoices */}
        <div 
          className={`glass-stat-card ${highlightedCard === 'invoices' ? 'card-pulse' : ''}`}
          style={{ ...styles.statCard, cursor: 'pointer' }}
          onClick={() => handleCardClick('invoices')}
        >
          <div style={styles.statIconContainer}>
            <AlertCircle size={20} color="#f87171" />
          </div>
          <div style={{ ...styles.statNumber, color: overdueInvoicesCount > 0 ? '#ef4444' : '#ffffff' }}>
            {overdueInvoicesCount}
          </div>
          <div style={styles.statLabel}>Overdue Invoices</div>
        </div>
      </div>

      {/* Two-Column Layout */}
      <div className="dashboard-content-grid" style={styles.mainGrid}>
        
        {/* Left Column: Tabbed Activity Lists Widget */}
        <div id="activity-table-section" style={styles.leftColumn}>
          <div style={styles.tabHeaderContainer}>
            <div style={styles.tabsWrapper}>
              <button 
                onClick={() => { setActiveTab('pos'); setSearchQuery(''); }}
                style={{ ...styles.tabBtn, ...(activeTab === 'pos' ? styles.tabBtnActive : {}) }}
              >
                Recent POs
              </button>
              <button 
                onClick={() => { setActiveTab('invoices'); setSearchQuery(''); }}
                style={{ ...styles.tabBtn, ...(activeTab === 'invoices' ? styles.tabBtnActive : {}) }}
              >
                Invoices
              </button>
              <button 
                onClick={() => { setActiveTab('rfqs'); setSearchQuery(''); }}
                style={{ ...styles.tabBtn, ...(activeTab === 'rfqs' ? styles.tabBtnActive : {}) }}
              >
                Active RFQs
              </button>
            </div>
            
            {/* Action List Search */}
            <div style={styles.searchWrapper}>
              <Search size={14} style={styles.searchIcon} />
              <input 
                type="text" 
                placeholder={`Search ${activeTab === 'pos' ? 'Purchase Orders' : activeTab === 'invoices' ? 'Invoices' : 'RFQs'}...`}
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                style={styles.searchInput}
              />
            </div>
          </div>

          <div className="custom-table-container" style={styles.tableCard}>
            <table style={styles.table}>
              {activeTab === 'pos' && (
                <>
                  <thead>
                    <tr style={styles.tableHeaderRow}>
                      <th style={styles.th}>PO #</th>
                      <th style={styles.th}>Vendor</th>
                      <th style={styles.th}>Date</th>
                      <th style={styles.th}>Amount</th>
                      <th style={styles.th}>Status</th>
                      <th style={styles.th}>Odoo Sync</th>
                    </tr>
                  </thead>
                  <tbody>
                    {currentListData.map(po => (
                      <tr key={po.id} style={styles.tr}>
                        <td style={{ ...styles.td, fontWeight: 'bold', color: '#ffffff' }}>{po.poNo}</td>
                        <td style={styles.td}>{po.vendor}</td>
                        <td style={styles.td}>{po.date}</td>
                        <td style={styles.td}>${po.amount.toLocaleString()}</td>
                        <td style={styles.td}>
                          <span className={`badge-status status-${po.status.toLowerCase()}`}>
                            {po.status}
                          </span>
                        </td>
                        <td style={styles.td}>
                          {po.syncStatus === 'synced' ? (
                            <span style={{ color: '#10b981', display: 'flex', alignItems: 'center', gap: '4px', fontSize: '0.8rem' }}>
                              <Check size={12} /> Synced
                            </span>
                          ) : po.syncStatus === 'pending' ? (
                            <span style={{ color: '#fbbf24', display: 'flex', alignItems: 'center', gap: '4px', fontSize: '0.8rem' }}>
                              <RefreshCw size={12} className="animate-spin" /> Sync Pending
                            </span>
                          ) : (
                            <button 
                              onClick={() => {
                                showToast(`Queued PO ${po.poNo} for Odoo synchronization.`);
                                setPurchaseOrders(prev => prev.map(p => p.id === po.id ? { ...p, syncStatus: 'pending' } : p));
                                setTimeout(() => {
                                  setPurchaseOrders(prev => prev.map(p => p.id === po.id ? { ...p, syncStatus: 'synced', status: 'Approved' } : p));
                                  showToast(`PO ${po.poNo} committed to Odoo successfully!`);
                                }, 1500);
                              }}
                              style={styles.inlineActionBtn}
                            >
                              Sync Now
                            </button>
                          )}
                        </td>
                      </tr>
                    ))}
                    {currentListData.length === 0 && (
                      <tr>
                        <td colSpan="6" style={styles.emptyTableText}>No purchase orders found matching search criteria.</td>
                      </tr>
                    )}
                  </tbody>
                </>
              )}

              {activeTab === 'invoices' && (
                <>
                  <thead>
                    <tr style={styles.tableHeaderRow}>
                      <th style={styles.th}>Invoice #</th>
                      <th style={styles.th}>PO Ref</th>
                      <th style={styles.th}>Vendor</th>
                      <th style={styles.th}>Due Date</th>
                      <th style={styles.th}>Amount</th>
                      <th style={styles.th}>Status</th>
                      <th style={styles.th}>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {currentListData.map(inv => (
                      <tr key={inv.id} style={styles.tr}>
                        <td style={{ ...styles.td, fontWeight: 'bold', color: '#ffffff' }}>{inv.invNo}</td>
                        <td style={styles.td}>{inv.poRef}</td>
                        <td style={styles.td}>{inv.vendor}</td>
                        <td style={styles.td}>{inv.dueDate}</td>
                        <td style={styles.td}>${inv.amount.toLocaleString()}</td>
                        <td style={styles.td}>
                          <span className={`badge-status status-${inv.status.toLowerCase()}`}>
                            {inv.status}
                          </span>
                        </td>
                        <td style={styles.td}>
                          {inv.status !== 'Paid' ? (
                            <button 
                              onClick={() => handlePayInvoice(inv.id, inv.invNo)}
                              style={styles.payActionBtn}
                            >
                              Pay Invoice
                            </button>
                          ) : (
                            <span style={{ color: '#10b981', display: 'flex', alignItems: 'center', gap: '4px', fontSize: '0.8rem' }}>
                              <Check size={12} /> Paid
                            </span>
                          )}
                        </td>
                      </tr>
                    ))}
                    {currentListData.length === 0 && (
                      <tr>
                        <td colSpan="7" style={styles.emptyTableText}>No invoices found matching search criteria.</td>
                      </tr>
                    )}
                  </tbody>
                </>
              )}

              {activeTab === 'rfqs' && (
                <>
                  <thead>
                    <tr style={styles.tableHeaderRow}>
                      <th style={styles.th}>RFQ #</th>
                      <th style={styles.th}>Title</th>
                      <th style={styles.th}>Budget</th>
                      <th style={styles.th}>Deadline</th>
                      <th style={styles.th}>Bids Recv</th>
                      <th style={styles.th}>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    {currentListData.map(rfq => (
                      <tr key={rfq.id} style={styles.tr}>
                        <td style={{ ...styles.td, fontWeight: 'bold', color: '#ffffff' }}>{rfq.rfqNo}</td>
                        <td style={styles.td}>{rfq.title}</td>
                        <td style={styles.td}>${rfq.budget.toLocaleString()}</td>
                        <td style={styles.td}>{rfq.deadline}</td>
                        <td style={styles.td}>
                          <span style={styles.badgeCount}>
                            {rfq.vendorCount} Vendors
                          </span>
                        </td>
                        <td style={styles.td}>
                          <span className={`badge-status status-${rfq.status.replace(' ', '-').toLowerCase()}`}>
                            {rfq.status}
                          </span>
                        </td>
                      </tr>
                    ))}
                    {currentListData.length === 0 && (
                      <tr>
                        <td colSpan="6" style={styles.emptyTableText}>No RFQs found matching search criteria.</td>
                      </tr>
                    )}
                  </tbody>
                </>
              )}
            </table>
          </div>
        </div>

        {/* Right Column: Pending Approvals & Quick Actions */}
        <div style={styles.rightColumn}>
          
          {/* Pending Approvals Widget */}
          <div id="approvals-section" style={styles.approvalsWidgetContainer}>
            <div style={styles.sectionHeaderRow}>
              <div style={styles.sectionTitle}>Pending Approvals</div>
              <span className="badge badge-primary">{approvals.length} Action Needed</span>
            </div>
            
            <div style={styles.approvalsList}>
              {approvals.map(app => {
                const isRemoving = removingApprovalId === app.id;
                return (
                  <div 
                    key={app.id} 
                    className={`approval-card ${isRemoving ? 'slide-out' : ''}`}
                    style={styles.approvalCard}
                  >
                    <div style={styles.approvalCardHeader}>
                      <span style={styles.approvalTypeTag}>{app.type}</span>
                      <span style={styles.approvalDate}>{app.date}</span>
                    </div>
                    
                    <h4 style={styles.approvalTitle}>{app.title}</h4>
                    
                    <div style={styles.approvalDetails}>
                      <div>
                        <span style={styles.detailLabel}>Vendor</span>
                        <span style={styles.detailValueText}>{app.vendor}</span>
                      </div>
                      <div>
                        <span style={styles.detailLabel}>Amount</span>
                        <span style={{ ...styles.detailValueText, color: '#e06b6b', fontWeight: 'bold' }}>
                          ${app.amount.toLocaleString()}
                        </span>
                      </div>
                      <div>
                        <span style={styles.detailLabel}>Requested By</span>
                        <span style={styles.detailValueText}>{app.requestor}</span>
                      </div>
                    </div>

                    <div style={styles.approvalActions}>
                      <button 
                        onClick={() => handleResolveApproval(app.id, 'approve', app.title)}
                        style={styles.approveButton}
                        title="Approve Request"
                      >
                        <Check size={14} />
                        <span>Approve</span>
                      </button>
                      <button 
                        onClick={() => handleResolveApproval(app.id, 'reject', app.title)}
                        style={styles.rejectButton}
                        title="Reject Request"
                      >
                        <X size={14} />
                        <span>Decline</span>
                      </button>
                    </div>
                  </div>
                );
              })}

              {approvals.length === 0 && (
                <div style={styles.emptyStateContainer}>
                  <div style={styles.emptyStateCheck}>
                    <Check size={28} color="#10b981" />
                  </div>
                  <h4 style={{ color: '#ffffff', margin: '10px 0 5px 0' }}>All Caught Up!</h4>
                  <p style={{ color: 'var(--text-muted)', fontSize: '0.85rem', textAlign: 'center' }}>
                    There are no pending procurement approvals requiring officer attention.
                  </p>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Divider */}
      <div style={styles.dividerContainer}>
        <div style={styles.divider}></div>
      </div>

